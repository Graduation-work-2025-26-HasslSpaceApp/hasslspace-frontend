<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HasslSpace" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.EmojiPicker" parent="Theme.AppCompat.Light" />

    <style name="Theme.EmojiPicker.Light" parent="Theme.EmojiPicker">
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/primary_text_light</item>
        <item name="android:textColorSecondary">@color/secondary_text_light</item>
        <item name="android:textColorHint">@color/hint_text_light</item>
        <item name="colorControlNormal">@color/icon_normal_light</item>
        <item name="colorAccent">@color/accent_light</item>
        <item name="colorPrimary">@color/accent_light</item>
    </style>

    <style name="Theme.EmojiPicker.Dark" parent="Theme.EmojiPicker">
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/primary_text_dark</item>
        <item name="android:textColorSecondary">@color/secondary_text_dark</item>
        <item name="android:textColorHint">@color/hint_text_dark</item>
        <item name="colorControlNormal">@color/icon_normal_dark</item>
        <item name="colorAccent">@color/accent_dark</item>
        <item name="colorPrimary">@color/accent_dark</item>
    </style>

    <color name="background_light">#FFFFFF</color>
    <color name="primary_text_light">#000000</color>
    <color name="secondary_text_light">#457B9D</color>
    <color name="hint_text_light">#A8DADC</color>
    <color name="icon_normal_light">#6D6F6E</color>
    <color name="accent_light">#F3D0B2</color>

    <color name="background_dark">#121212</color>
    <color name="primary_text_dark">#FFFFFF</color>
    <color name="secondary_text_dark">#A8DADC</color>
    <color name="hint_text_dark">#457B9D</color>
    <color name="icon_normal_dark">#A0A0A0</color>
    <color name="accent_dark">#C6C49366</color>

</resources>